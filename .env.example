# Anthropic Claude API (only needed for AGENT_MODE=agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Resend email — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Market Agent <onboarding@resend.dev>
EMAIL_TO=you@example.com

# Agent mode: "agent" (Claude loop) or "pipeline" (direct, no LLM)
AGENT_MODE=pipeline

# GitHub Actions — set as repository secrets (RESEND_API_KEY, EMAIL_FROM, EMAIL_TO)
# Local runs use this file; Actions inject secrets at runtime.

# Scheduler — all times Eastern (ET); run: python scheduler.py
DAILY_AM_SCHEDULE_HOUR=11
DAILY_AM_SCHEDULE_MINUTE=30
SCHEDULE_HOUR=19
SCHEDULE_MINUTE=4
WEEKLY_SCHEDULE_HOUR=10
WEEKLY_SCHEDULE_MINUTE=6
MONTHLY_SCHEDULE_HOUR=19
MONTHLY_SCHEDULE_MINUTE=0

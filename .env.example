# Anthropic Claude API (only needed for AGENT_MODE=agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Resend email — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Market Agent <onboarding@resend.dev>
EMAIL_TO=you@example.com

# Agent mode: "agent" (Claude loop) or "pipeline" (direct, no LLM)
AGENT_MODE=pipeline

# Scheduler — daily 7:04 PM ET on trading days, weekly Sat 10:06 AM CST
SCHEDULE_HOUR=19
SCHEDULE_MINUTE=4
WEEKLY_SCHEDULE_HOUR=10
WEEKLY_SCHEDULE_MINUTE=6
MONTHLY_SCHEDULE_HOUR=10
MONTHLY_SCHEDULE_MINUTE=6
